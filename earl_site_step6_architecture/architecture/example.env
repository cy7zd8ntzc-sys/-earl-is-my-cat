# Example environment variables for production planning only.
# Do not commit real secrets.

APP_ENV=production
APP_BASE_URL=https://app.earlismycat.com
PROVIDER_BASE_URL=https://provider.earlismycat.com
PUBLIC_SITE_URL=https://earlismycat.com

# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/eimc_prod

# AWS / storage
AWS_REGION=us-east-1
AWS_PHOTO_BUCKET=eimc-prod-clinical-photos
AWS_KMS_KEY_ID=alias/eimc-prod-phi
AWS_PRESIGNED_UPLOAD_TTL_SECONDS=600
AWS_PRESIGNED_DOWNLOAD_TTL_SECONDS=300

# Auth
AUTH_PROVIDER=cognito
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
PROVIDER_MFA_REQUIRED=true
PATIENT_SESSION_IDLE_MINUTES=30
PROVIDER_SESSION_IDLE_MINUTES=15

# Stripe
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_VISIT_PRICE_ID=
STRIPE_GENERIC_PRODUCT_NAME="Online dermatology visit"

# Pharmacy
DEFAULT_PHARMACY_ID=
PHARMACY_HANDOFF_MODE=secure_portal
PHARMACY_PORTAL_URL=

# Security
LOG_LEVEL=info
ALLOW_PHI_IN_LOGS=false
ENABLE_AUDIT_LOGS=true
ENABLE_EXIF_STRIP=true
MAX_PHOTO_SIZE_MB=15
SUPPORTED_STATES=TX,CO,FL
